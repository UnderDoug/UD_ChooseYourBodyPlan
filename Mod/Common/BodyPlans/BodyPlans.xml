  <bodyplan Name="BaseTransformation">
    <optionID>EnableBodyPlansAvailableViaRecipe</optionID>
    <textElement Name="Transformation" />
    <base>NoInherit</base>
  </bodyplan>
  
  <bodyplan Name="SlugWithHands" Category="Mollusk" Inherits="BaseTransformation">
    <render>
      <displayName>Slug With Hands</displayName>
      <tile>Creatures/sw_slog.bmp</tile>
      <renderString>Q</renderString>
      <colorString>&amp;G</colorString>
      <tileColor>&amp;M</tileColor>
      <detailColor>G</detailColor>
    </render>
    <transformation>
      <property Name="AteCloacaSurprise" Value="true" />
      <mutations>Bilge Sphincter</mutations>
      <render>
        <tile>Creatures/sw_slog.bmp</tile>
        <renderString>Q</renderString>
      </render>
      <species>slug</species>
    </transformation>
  </bodyplan>
  
  <bodyplan Name="HumanoidOctohedron" Category="Crystal" Inherits="BaseTransformation">
    <render>
      <displayName>Humanoid Octohedron</displayName>
      <tile>Creatures/sw_crystal_body.png</tile>
      <renderString>µ</renderString>
      <colorString>&amp;Y</colorString>
      <tileColor>&amp;Y</tileColor>
      <detailColor>m</detailColor>
    </render>
    <transformation>
      <property Name="AteCrystalDelight" Value="true" />
